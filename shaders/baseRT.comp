}
void main() {
    uint kx = gl_GlobalInvocationID.x;
    uint ky = gl_GlobalInvocationID.y;
    uvec2 size = imageSize(outImage);
    if (kx >= size.x || ky >= size.y) return;

    ivec2 pixels = ivec2(kx, ky);
    uint seed = init_seed(gl_GlobalInvocationID.xy, frameInfo.frameCount);

    float aspect = float(size.x) / float(size.y);
    vec2 ndc = (vec2(kx, ky) + .5f) / size;
    vec2 uv = 2.f * ndc - 1.f;
    uv.x = uv.x * aspect;
    float focalLength = 1.f;

    Ray ray;
    ray.start = vec3(0, 0, 3.f);
    ray.direction = normalize(vec3(uv, -focalLength));

    Sphere sphere = Sphere(vec3(0, 0, 0), 1);
    vec3 color = vec3(0);
    vec3 throuput = vec3(1);
    vec3 atten = vec3(1.f);

    for (int i = 0; i < 50; i++) {
        HitRecord record;
        record.t = 0;
        if (hit_sphere(ray, scene.objects[0], record) == 1) {
            ray.start = record.p + (record.normal * .001);
            ray.direction = scatter_random(record.normal, seed);
            atten *= .5f;
            vec3 surfaceColor = (record.normal + 1) * atten;
            throuput *= surfaceColor;
        } else {
            float a = .5 * (ray.direction.y + 1);
            vec3 skyColor = (vec3(1) * (1 - a)) + vec3(0.5, 0.7, 1.0) * a;;
            color = skyColor * throuput;
            break;
        }
    }
    if (frameInfo.frameCount == 1) {
        imageStore(outImage, pixels, vec4(color, 1));
    } else {
        vec3 prevColor = imageLoad(outImage, pixels).rgb;
        float weight = 1 / float(frameInfo.frameCount);
        vec3 accColor = mix(prevColor, color, weight);
        imageStore(outImage, pixels, vec4(accColor, 1));
    }

}